---
import { Picture } from "astro:assets";
import heroProductImage from "@/assets/edgeever-hero-product.png";
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
import { Meteors } from "@/components/magicui/meteors";
import { getLocalizedPath, getSiteLocale, siteCopy } from "@/i18n";

const locale = getSiteLocale(Astro.url.pathname);
const copy = siteCopy[locale].hero;
---

<main class="relative grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(420px,1.05fr)] place-items-center pt-8 pb-8 md:pt-10 md:pb-8 overflow-hidden">
  <!-- Animated Background Orbs -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand/10 rounded-full blur-3xl animate-slow-spin mix-blend-multiply pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-brand-border/20 rounded-full blur-3xl animate-float mix-blend-multiply pointer-events-none"></div>

  <!-- Magic UI Meteors -->
  <Meteors number={20} client:load />

  <div class="md:order-1 relative z-10 w-full">
    {copy.badgeText && (
      <a
        href={`${getLocalizedPath(locale, "/")}blog?tag=migration`}
        class="inline-flex items-center gap-2 px-3.5 py-1 mb-6 text-xs text-brand bg-brand/5 border border-brand-border/30 hover:border-brand/40 hover:bg-brand/10 rounded-full backdrop-blur-sm select-none hover:-translate-y-0.5 transition-all duration-300 group/badge cursor-pointer"
      >
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand"></span>
        </span>
        <span class="text-slate-600 font-medium group-hover/badge:text-brand transition-colors">{copy.badgeText}</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-slate-400 group-hover/badge:text-brand transition-all duration-300 transform group-hover/badge:translate-x-0.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </a>
    )}
    <h1 class="text-4xl md:text-5xl xl:text-6xl font-bold text-slate-900 leading-tight">
      <span class="text-gradient">EdgeEver</span>
      <span class="hero-slogan block mt-4 max-w-xl text-xl md:text-2xl font-medium leading-relaxed text-slate-700">{copy.slogan}</span>
    </h1>

    <div class="mt-8 flex flex-col sm:flex-row gap-4">
      <Link
        href="https://demo.edgeever.org"
        target="_blank"
        class="group flex gap-2 items-center justify-center text-white bg-brand border-transparent shadow-[0_12px_30px_-18px_rgb(var(--edgeever-brand-rgb)/0.8)] hover:bg-brand-hover hover:shadow-brand/40 transition-all duration-300 hover:-translate-y-1 rounded-xl"
        rel="noopener">
        <Icon class="w-5 h-5" name="bx:bx-show" />
        {copy.demo}
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="https://github.com/tianma-if/edgeever"
        class="flex gap-2 items-center justify-center hover:bg-slate-50 transition-colors rounded-xl"
        target="_blank">
        <Icon class="text-slate-700 w-5 h-5" name="bx:bxl-github" />
        GitHub
      </Link>
      <a
        rel="noopener"
        href={getLocalizedPath(locale, "/blog/ai-agent-deploy-cloudflare")}
        class="flex gap-2 items-center justify-center px-6 py-3 bg-white/50 backdrop-blur-sm border border-slate-200 hover:border-slate-300 rounded-xl text-slate-600 hover:text-brand-text transition-all text-sm font-medium hover:-translate-y-0.5"
        >
        <Icon class="w-5 h-5" name="bx:bxs-bot" />
        {copy.agentInstall}
      </a>
    </div>
  </div>

  <div class="py-3 md:order-2 hidden md:flex relative w-full max-w-lg justify-center z-10">
    <div class="relative w-full glow-card rounded-2xl p-2.5 animate-float" style="animation-delay: 1s;">
      <div class="absolute -inset-0.5 bg-gradient-to-tr from-brand-border/30 to-brand/10 rounded-2xl blur opacity-50"></div>
      <Picture
        src={heroProductImage}
        alt={copy.imageAlt}
        widths={[480, 720, 960, 1200]}
        sizes="(max-width: 1024px) 100vw, 640px"
        loading="eager"
        format="avif"
        class="relative rounded-xl border border-white/40 shadow-2xl z-10"
      />
    </div>
  </div>
</main>

<style>
  .hero-slogan {
    font-family:
      "Inter Variable",
      Inter,
      "PingFang SC",
      "Hiragino Sans GB",
      "Microsoft YaHei",
      ui-sans-serif,
      system-ui,
      sans-serif;
  }
</style>
