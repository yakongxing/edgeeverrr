---
import { getLocalizedPath, getSiteLocale, siteCopy } from "@/i18n";

const locale = getSiteLocale(Astro.url.pathname);
const copy = siteCopy[locale].guides;
---

<section class="mt-16 md:mt-24" aria-labelledby="guides">
  <div class="max-w-3xl">
    <p class="text-sm font-semibold text-brand-text">{copy.eyebrow}</p>
    <h2 id="guides" class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
      {copy.heading}
    </h2>
    <p class="mt-4 text-lg leading-8 text-slate-600">
      {copy.description}
    </p>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-3">
    {
      copy.items.map((item) => (
        <a
          href={getLocalizedPath(locale, item.href)}
          class="group flex min-h-64 flex-col justify-between rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-border hover:shadow-lg"
        >
          <div>
            <h3 class="text-xl font-bold text-slate-900 transition group-hover:text-brand-text">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{item.summary}</p>
          </div>
          <span class="mt-6 text-sm font-semibold text-brand-text">{item.cta}</span>
        </a>
      ))
    }
  </div>
</section>
