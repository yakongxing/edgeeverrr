---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";

const title = "EdgeEver AI Agent advanced plays";
const description = "Use EdgeEver MCP to let AI agents organize real notes into persona profiles, knowledge maps, and cleaner tag systems.";

const prompts = [
  {
    title: "Persona profile",
    summary: "Extract long-term themes, work preferences, capability signals, recurring problems, and recent direction from your notes.",
    prompt:
      "Use EdgeEver MCP to read my notes and create a persona profile based on the real note content. Judge only from evidence in the notes, do not make psychological diagnoses, and do not exaggerate traits. Include long-term themes, work preferences, capability signals, recurring problems, recent direction, and list related note titles or memo ids after each conclusion.",
  },
  {
    title: "Knowledge map",
    summary: "Organize notes into knowledge areas, key concepts, related material, what you already understand, and gaps to fill.",
    prompt:
      "Use EdgeEver MCP to read my notes and organize a knowledge map. Identify the main knowledge areas, key concepts in each area, related notes, what I already understand, and the gaps I still need to fill. Structure the output so it is useful for continued learning and writing.",
  },
  {
    title: "Tag suggestions",
    summary: "Review existing notes and tags to find duplicate, narrow, broad, or inconsistent labels before applying changes.",
    prompt:
      "Use EdgeEver MCP to read my notes and existing tags, then design a clearer tag system. Point out duplicate, overly narrow, overly broad, or inconsistently named tags, and suggest merges, renames, and new tags. Do not modify notes yet. Wait for my confirmation before applying changes.",
  },
];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  url: pageUrl,
  inLanguage: "en-US",
  publisher: {
    "@type": "Organization",
    name: "EdgeEver",
  },
};
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <Container>
    <main class="mx-auto max-w-4xl py-16 md:py-24">
      <p class="text-sm font-semibold text-brand-text">AI Agent Workflow</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">{title}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">{description}</p>

      <div class="mt-10 space-y-5">
        {
          prompts.map((item) => (
            <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <h2 class="text-2xl font-bold text-slate-900">{item.title}</h2>
              <p class="mt-3 text-base leading-7 text-slate-600">{item.summary}</p>
              <pre class="mt-5 overflow-x-auto rounded-lg bg-slate-950 p-4 text-sm leading-6 text-slate-100"><code>{item.prompt}</code></pre>
            </article>
          ))
        }
      </div>
    </main>
  </Container>
</Layout>
