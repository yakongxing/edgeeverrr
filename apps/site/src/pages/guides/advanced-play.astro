---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";

const title = "EdgeEver AI Agent 进阶玩法";
const description = "通过 EdgeEver MCP 读取真实笔记，让 AI Agent 辅助整理人物画像、知识图谱和标签体系。";

const prompts = [
  {
    title: "人物画像",
    summary: "从长期笔记中提炼关注主题、做事偏好、能力线索、反复出现的问题和近期动向。",
    prompt:
      "请通过 EdgeEver MCP 读取我的笔记，基于真实笔记内容为我整理一份人物画像。请只根据笔记中的证据判断，不要做心理诊断，不要夸张定性。输出包括：长期关注的主题、做事偏好、能力线索、反复出现的问题、近期动向，并在每条结论后列出相关笔记标题或 memo id。",
  },
  {
    title: "知识图谱",
    summary: "把笔记拆成主要知识领域、关键概念、相关材料、已掌握部分和待补齐问题。",
    prompt:
      "请通过 EdgeEver MCP 读取我的笔记，为我整理一份知识地图。请找出主要知识领域、每个领域下的关键概念、相关笔记、我已经掌握的部分和还需要补齐的问题。输出结构要适合后续继续学习和写作。",
  },
  {
    title: "标签建议",
    summary: "基于已有笔记和标签，发现重复、过细、过宽或命名不一致的问题。",
    prompt:
      "请通过 EdgeEver MCP 读取我的笔记和现有标签，帮我设计一套更清晰的标签体系。请指出重复、过细、过宽或命名不一致的标签，并给出合并、重命名和新增标签建议。先不要修改笔记，等我确认后再执行。",
  },
];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  url: pageUrl,
  inLanguage: "zh-CN",
  publisher: {
    "@type": "Organization",
    name: "EdgeEver",
  },
};
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <Container>
    <main class="mx-auto max-w-4xl py-16 md:py-24">
      <p class="text-sm font-semibold text-brand-text">AI Agent Workflow</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">{title}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">{description}</p>

      <div class="mt-10 space-y-5">
        {
          prompts.map((item) => (
            <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <h2 class="text-2xl font-bold text-slate-900">{item.title}</h2>
              <p class="mt-3 text-base leading-7 text-slate-600">{item.summary}</p>
              <pre class="mt-5 overflow-x-auto rounded-lg bg-slate-950 p-4 text-sm leading-6 text-slate-100"><code>{item.prompt}</code></pre>
            </article>
          ))
        }
      </div>
    </main>
  </Container>
</Layout>
