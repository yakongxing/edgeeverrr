---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout
  title="联系我们"
  description="EdgeEver 联系与社区交流入口。Bug、功能建议和部署问题建议优先通过 GitHub Issues 沉淀。"
>
  <Container>
    <main class="mx-auto max-w-3xl py-12 md:py-20 text-slate-700">
      <section class="rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
        <a
          href="https://github.com/tianma-if/edgeever/issues"
          target="_blank"
          class="group block"
        >
          <div class="flex items-start gap-4">
            <Icon class="text-gray-700 w-8 h-8 shrink-0 mt-0.5 transition group-hover:text-brand-text" name="bx:bxl-github" />
            <div>
              <h1 class="text-2xl font-bold text-gray-900 transition group-hover:text-brand-text">GitHub Issues</h1>
              <p class="mt-3 text-base leading-7 text-slate-500">
                适用于提交软件故障、错误报告、部署问题或明确的功能请求。
              </p>
            </div>
          </div>
        </a>

        <div class="mt-8 border-t border-slate-200 pt-6">
          <h2 class="font-bold text-xl text-gray-900">其他联系信息</h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div class="flex items-center gap-3 rounded-lg bg-slate-50 px-4 py-3">
              <Icon class="text-gray-400 w-5 h-5 shrink-0" name="bx:bx-message-rounded" />
              <span class="text-gray-600">微信：m1245207870</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg bg-slate-50 px-4 py-3">
              <Icon class="text-gray-400 w-5 h-5 shrink-0" name="bx:bx-globe" />
              <span class="text-gray-600">主域名：edgeever.org</span>
            </div>
          </div>
          <p class="mt-4 text-xs leading-normal text-slate-400">
            私下沟通请备注 EdgeEver。
          </p>
        </div>
      </section>
    </main>
  </Container>
</Layout>
