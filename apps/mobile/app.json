{
  "expo": {
    "name": "EdgeEver",
    "slug": "edgeever",
    "scheme": "edgeever",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/59d2a8c8-fe8f-4e59-874f-a5887f584a20",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "org.edgeever.mobile",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.edgeever.mobile",
      "versionCode": 26,
      "adaptiveIcon": {
        "backgroundColor": "#d1fae5",
        "backgroundImage": "./assets/icon.png",
        "foregroundImage": "./assets/adaptive-icon-transparent.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#D9FAEA",
          "image": "./assets/icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "usesCleartextTraffic": true,
            "targetSdkVersion": 36,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59d2a8c8-fe8f-4e59-874f-a5887f584a20"
      }
    },
    "owner": "tianma-if-edgeever"
  }
}
