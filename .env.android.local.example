# Absolute path to the existing Google Play upload key. Keep the key outside
# the repository and never commit the populated .env.android.local file.
ANDROID_KEYSTORE_FILE=/Users/your-name/.config/edgeever/android/edgeever-upload.p12
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# Optional. The default includes all Play-supported Android architectures.
EDGE_EVER_ANDROID_ARCHS=armeabi-v7a,arm64-v8a,x86,x86_64
